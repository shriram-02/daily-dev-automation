# Never commit real secrets. GitHub Actions should use repository secrets.
DDA_DRY_RUN=true
DDA_LOCAL_MODE=true
DDA_TIMEZONE=America/Indianapolis
DDA_MAX_COMMITS_PER_DAY=8
DDA_MIN_MINUTES_BETWEEN_COMMITS=90
DDA_QUIET_HOURS_START=22:00
DDA_QUIET_HOURS_END=06:00
DDA_ALLOWED_BRANCH=main
DDA_GIT_AUTHOR_NAME=daily-dev-automation
DDA_GIT_AUTHOR_EMAIL=41898282+github-actions[bot]@users.noreply.github.com
